# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados
DB_PATH=./data/versozap.db

# WhatsApp (pasta onde as credenciais da sessão são salvas)
WA_SESSION_PATH=./data/wa_session

# Segurança da API
API_SECRET=troca_por_uma_chave_aleatoria_longa

# Configurações de envio
MAX_REENVIOS=2
HORARIO_LEMBRETE=20:00

# Fuso horário do servidor (essencial para o agendador comparar horários corretamente)
TZ=America/Sao_Paulo

# Segurança JWT (use uma string longa e aleatória em produção)
JWT_SECRET=troca_por_uma_chave_jwt_longa_e_aleatoria
